<?xml version="1.0" encoding="UTF-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/color_303030"
    android:orientation="vertical">

    <TextView
        android:textSize="30sp"
        android:textColor="@color/white"
        android:layout_width="match_parent"
        android:layout_height="66dp"
        android:background="@color/color_424242"
        android:gravity="center"
        android:orientation="horizontal"
        android:text="@string/date" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="25dp"
        android:gravity="center_horizontal"
        android:layout_weight="1">

        <TextView
            android:id="@+id/tv_year_name"
            android:textSize="24sp"
            android:textColor="@color/white"
            android:layout_height="wrap_content"
            android:layout_width="124dp"
            android:layout_marginStart="0dp"
            android:gravity="center"
            android:text="@string/year" />

        <RelativeLayout
            android:id="@+id/rl_year"
            android:layout_width="124dp"
            android:layout_height="wrap_content"
            android:layout_below="@id/tv_year_name"
            android:layout_alignStart="@id/tv_year_name"
            android:layout_marginTop="11dp"
            android:layout_marginBottom="50dp"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/iv_add_year"
                android:layout_width="124dp"
                android:layout_height="36dp"
                android:layout_centerHorizontal="true"
                android:background="@drawable/c_2c2e_2122_selector"
                android:clickable="true"
                android:focusable="true"
                android:src="@drawable/ic_add_aaruy" />

            <TextView
                android:id="@+id/tv_year_value"
                android:textSize="24sp"
                android:textColor="@color/white"
                android:gravity="center"
                android:layout_width="124dp"
                android:layout_height="84dp"
                android:layout_below="@id/iv_add_year"
                android:layout_alignStart="@id/iv_add_year"
                android:layout_centerVertical="true"
                android:background="@color/color_373737"
                android:text="2021" />

            <ImageView
                android:id="@+id/iv_minus_year"
                android:layout_width="124dp"
                android:layout_height="36dp"
                android:layout_below="@id/tv_year_value"
                android:layout_alignStart="@id/tv_year_value"
                android:layout_centerHorizontal="true"
                android:background="@drawable/c_2c2e_2122_selector"
                android:clickable="true"
                android:focusable="true"
                android:src="@drawable/ic_minus_aaruy" />


        </RelativeLayout>

        <TextView
            android:id="@+id/tv_month_name"
            android:textSize="24sp"
            android:textColor="@color/white"
            android:gravity="center"
            android:layout_height="wrap_content"
            android:layout_width="88dp"
            android:layout_marginStart="10dp"
            android:layout_toEndOf="@id/tv_year_name"
            android:text="@string/month" />

        <RelativeLayout
            android:id="@+id/rl_month"
            android:layout_width="88dp"
            android:layout_height="wrap_content"
            android:layout_below="@id/tv_month_name"
            android:layout_alignStart="@id/tv_month_name"
            android:layout_marginTop="11dp"
            android:layout_marginBottom="50dp"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/iv_add_month"
                android:layout_width="88dp"
                android:layout_height="36dp"
                android:layout_centerHorizontal="true"
                android:background="@drawable/c_2c2e_2122_selector"
                android:clickable="true"
                android:focusable="true"
                android:src="@drawable/ic_add_aaruy" />

            <TextView
                android:id="@+id/tv_month_value"
                android:textSize="24sp"
                android:textColor="@color/white"
                android:gravity="center"
                android:layout_width="88dp"
                android:layout_height="84dp"
                android:layout_below="@id/iv_add_month"
                android:layout_alignStart="@id/iv_add_month"
                android:layout_centerVertical="true"
                android:background="@color/color_373737"
                android:text="2" />

            <ImageView
                android:id="@+id/iv_minus_month"
                android:layout_width="124dp"
                android:layout_height="36dp"
                android:layout_below="@id/tv_month_value"
                android:layout_alignStart="@id/tv_month_value"
                android:layout_centerHorizontal="true"
                android:background="@drawable/c_2c2e_2122_selector"
                android:clickable="true"
                android:focusable="true"
                android:src="@drawable/ic_minus" />


        </RelativeLayout>

        <TextView
            android:id="@+id/tv_day_name"
            android:textSize="24sp"
            android:textColor="@color/white"
            android:gravity="center"
            android:layout_height="wrap_content"
            android:layout_width="88dp"
            android:layout_marginStart="10dp"
            android:layout_toEndOf="@id/tv_month_name"
            android:text="@string/day" />

        <RelativeLayout
            android:id="@+id/rl_day"
            android:layout_width="88dp"
            android:layout_height="wrap_content"
            android:layout_below="@id/tv_day_name"
            android:layout_alignStart="@id/tv_day_name"
            android:layout_marginTop="11dp"
            android:layout_marginBottom="50dp"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/iv_add_day"
                android:layout_width="88dp"
                android:layout_height="36dp"
                android:layout_centerHorizontal="true"
                android:background="@drawable/c_2c2e_2122_selector"
                android:clickable="true"
                android:focusable="true"
                android:src="@drawable/ic_add_aaruy" />

            <TextView
                android:id="@+id/tv_day_value"
                android:textSize="24sp"
                android:textColor="@color/white"
                android:gravity="center"
                android:layout_width="88dp"
                android:layout_height="84dp"
                android:layout_below="@id/iv_add_day"
                android:layout_alignStart="@id/iv_add_day"
                android:background="@color/color_373737"
                android:text="21" />

            <ImageView
                android:id="@+id/iv_minus_day"
                android:layout_width="124dp"
                android:layout_height="36dp"
                android:layout_below="@id/tv_day_value"
                android:layout_alignStart="@id/tv_day_value"
                android:layout_centerHorizontal="true"
                android:background="@drawable/c_2c2e_2122_selector"
                android:clickable="true"
                android:focusable="true"
                android:src="@drawable/ic_minus" />


        </RelativeLayout>

    </RelativeLayout>


    <LinearLayout
        style="@style/ll_horizontal_match_wrap"
        android:layout_height="66dp">

        <Button
            android:id="@+id/btn_positive"
            android:textSize="26sp"
            android:textColor="@color/white"
            android:gravity="center"
            android:layout_height="wrap_content"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:background="@drawable/app_to_alpha"
            android:padding="15dp"
            android:text="@string/ok" />

        <View style="@style/divider_vertical_1px" />

        <Button
            android:id="@+id/btn_negative"
            android:textSize="26sp"
            android:textColor="@color/white"
            android:gravity="center"
            android:layout_height="wrap_content"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:background="@drawable/app_to_alpha"
            android:padding="15dp"
            android:text="@string/cancel"
            android:visibility="visible" />

    </LinearLayout>

</LinearLayout>